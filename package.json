{
  "name": "clockin-mcp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "pnpm build && vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types ./worker-configuration.d.ts",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply clockin-mcp --local",
    "db:migrate:remote": "wrangler d1 migrations apply clockin-mcp --remote",
    "auth:generate": "better-auth generate --yes --output app/lib/db/auth-schema.ts --config app/lib/auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/oauth-provider": "^1.6.11",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-d1": "^0.49.0",
    "@effect/sql-drizzle": "^0.50.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "isbot": "^5.1.36",
    "lucide-react": "^1.16.0",
    "mcp-handler": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.76.1",
    "react-router": "7.13.1",
    "remix-utils": "^9.3.1",
    "shadcn": "^4.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4.20260528.1",
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.95.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
